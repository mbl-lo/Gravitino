generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @db.VarChar(255)
  inn                String              @unique @db.VarChar(12)
  kpp                String?             @db.VarChar(9)
  legalAddress       String?             @map("legal_address") @db.VarChar(500)
  status             String              @default("active") @db.VarChar(32)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)
  departments        Department[]
  integrationConfigs IntegrationConfig[]
  users              User[]

  @@map("organizations")
}

model Department {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  code           String       @db.VarChar(64)
  address        String?      @db.VarChar(500)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  drivers        Driver[]
  users          User[]
  vehicles       Vehicle[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model User {
  id                   String            @id @default(uuid()) @db.Uuid
  organizationId       String            @map("organization_id") @db.Uuid
  departmentId         String?           @map("department_id") @db.Uuid
  email                String            @unique @db.VarChar(255)
  passwordHash         String            @map("password_hash") @db.VarChar(255)
  fullName             String            @map("full_name") @db.VarChar(255)
  role                 String            @default("operator") @db.VarChar(64)
  isActive             Boolean           @default(true) @map("is_active")
  lastLoginAt          DateTime?         @map("last_login_at") @db.Timestamp(6)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)
  department           Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs            AuditLog[]
  confirmedDocuments   Document[]        @relation("DocumentConfirmedBy")
  documentHistory      DocumentHistory[]
  resolvedAnomalies    Anomaly[]         @relation("AnomalyResolvedBy")
  uploadedDocuments    Document[]        @relation("DocumentUploadedBy")

  @@index([organizationId])
  @@index([departmentId])
  @@map("users")
}

model Driver {
  id              String     @id @default(uuid()) @db.Uuid
  departmentId    String     @map("department_id") @db.Uuid
  fullName        String     @map("full_name") @db.VarChar(255)
  personnelNumber String     @map("personnel_number") @db.VarChar(64)
  licenseNumber   String     @map("license_number") @db.VarChar(64)
  phone           String?    @db.VarChar(32)
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  documents       Document[]

  @@unique([departmentId, personnelNumber])
  @@unique([departmentId, licenseNumber])
  @@index([departmentId])
  @@map("drivers")
}

model Vehicle {
  id               String     @id @default(uuid()) @db.Uuid
  departmentId     String     @map("department_id") @db.Uuid
  vehicleNumber    String     @map("vehicle_number") @db.VarChar(32)
  brand            String     @db.VarChar(128)
  model            String     @db.VarChar(128)
  vehicleType      String     @map("vehicle_type") @db.VarChar(64)
  fuelRatePer100km Decimal?   @map("fuel_rate_per_100km") @db.Decimal(6, 2)
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  department       Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  documents        Document[]

  @@unique([departmentId, vehicleNumber])
  @@index([departmentId])
  @@map("vehicles")
}

model Document {
  id               String            @id @default(uuid()) @db.Uuid
  uploadedById     String            @map("uploaded_by_id") @db.Uuid
  driverId         String?           @map("driver_id") @db.Uuid
  vehicleId        String?           @map("vehicle_id") @db.Uuid
  documentNumber   String?           @map("document_number") @db.VarChar(64)
  tripDate         DateTime?         @map("trip_date") @db.Date
  originalFileUrl  String            @map("original_file_url") @db.VarChar(1024)
  originalFileName String            @map("original_file_name") @db.VarChar(255)
  fileMimeType     String            @map("file_mime_type") @db.VarChar(128)
  fileSize         Int               @map("file_size")
  status           String            @default("uploaded") @db.VarChar(64)
  ocrStatus        String            @default("pending") @map("ocr_status") @db.VarChar(64)
  ocrConfidence    Decimal?          @map("ocr_confidence") @db.Decimal(5, 4)
  hasAnomalies     Boolean           @default(false) @map("has_anomalies")
  confirmedAt      DateTime?         @map("confirmed_at") @db.Timestamp(6)
  confirmedById    String?           @map("confirmed_by_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)
  confirmedBy      User?             @relation("DocumentConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  driver           Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  uploadedBy       User              @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  vehicle          Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  anomalies        Anomaly[]
  exportJobs       ExportJob[]
  fields           DocumentField[]
  history          DocumentHistory[]
  processingJobs   ProcessingJob[]

  @@index([uploadedById])
  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([ocrStatus])
  @@map("documents")
}

model DocumentField {
  id              String   @id @default(uuid()) @db.Uuid
  documentId      String   @map("document_id") @db.Uuid
  fieldKey        String   @map("field_key") @db.VarChar(128)
  fieldLabel      String   @map("field_label") @db.VarChar(255)
  recognizedValue String?  @map("recognized_value") @db.Text
  correctedValue  String?  @map("corrected_value") @db.Text
  confidence      Decimal? @db.Decimal(5, 4)
  isEdited        Boolean  @default(false) @map("is_edited")
  bbox            Json?
  source          String?  @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, fieldKey])
  @@index([documentId])
  @@map("document_fields")
}

model ValidationRule {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(128)
  title       String    @db.VarChar(255)
  description String?   @db.Text
  isEnabled   Boolean   @default(true) @map("is_enabled")
  params      Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  anomalies   Anomaly[]

  @@map("validation_rules")
}

model Anomaly {
  id               String          @id @default(uuid()) @db.Uuid
  documentId       String          @map("document_id") @db.Uuid
  validationRuleId String?         @map("validation_rule_id") @db.Uuid
  type             String          @db.VarChar(128)
  severity         String          @db.VarChar(32)
  fieldKey         String?         @map("field_key") @db.VarChar(128)
  message          String          @db.Text
  expectedValue    String?         @map("expected_value") @db.Text
  actualValue      String?         @map("actual_value") @db.Text
  status           String          @default("open") @db.VarChar(64)
  resolvedById     String?         @map("resolved_by_id") @db.Uuid
  resolvedAt       DateTime?       @map("resolved_at") @db.Timestamp(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  document         Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  resolvedBy       User?           @relation("AnomalyResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  validationRule   ValidationRule? @relation(fields: [validationRuleId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([validationRuleId])
  @@index([status])
  @@map("anomalies")
}

model ProcessingJob {
  id           String    @id @default(uuid()) @db.Uuid
  documentId   String    @map("document_id") @db.Uuid
  jobType      String    @map("job_type") @db.VarChar(64)
  status       String    @default("queued") @db.VarChar(64)
  progress     Int       @default(0)
  errorMessage String?   @map("error_message") @db.Text
  startedAt    DateTime? @map("started_at") @db.Timestamp(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@map("processing_jobs")
}

model IntegrationConfig {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  integrationType  String       @map("integration_type") @db.VarChar(64)
  name             String       @db.VarChar(255)
  status           String       @default("active") @db.VarChar(64)
  settings         Json?
  lastSyncAt       DateTime?    @map("last_sync_at") @db.Timestamp(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  exportJobs       ExportJob[]

  @@index([organizationId])
  @@map("integration_configs")
}

model ExportJob {
  id                  String             @id @default(uuid()) @db.Uuid
  documentId          String             @map("document_id") @db.Uuid
  integrationConfigId String?            @map("integration_config_id") @db.Uuid
  exportFormat        String             @map("export_format") @db.VarChar(64)
  status              String             @default("queued") @db.VarChar(64)
  fileUrl             String?            @map("file_url") @db.VarChar(1024)
  errorMessage        String?            @map("error_message") @db.Text
  exportedAt          DateTime?          @map("exported_at") @db.Timestamp(6)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamp(6)
  document            Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  integrationConfig   IntegrationConfig? @relation(fields: [integrationConfigId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([integrationConfigId])
  @@index([status])
  @@map("export_jobs")
}

model DocumentHistory {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(128)
  fieldKey   String?  @map("field_key") @db.VarChar(128)
  oldValue   String?  @map("old_value") @db.Text
  newValue   String?  @map("new_value") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([documentId])
  @@index([userId])
  @@map("document_history")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(128)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(128)
  payload    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
